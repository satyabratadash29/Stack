fun stockPrice(arr: Array<Int>) : Array<Int>{
    val stack = ArrayDeque<Int>()
    val res = mutableListOf<Int>()
    val countStack = ArrayDeque<Int>()
    for(i in 0..arr.lastIndex){
        if(stack.isEmpty()){
            stack.add(arr[i])
            countStack.add(1)
            res.add(1)
        }else if(arr[i] >= stack.last()){
            var count = 1
            while(stack.isNotEmpty() && arr[i] >= stack.last()){
                stack.removeLast()
                count= count+ countStack.last()
                countStack.removeLast()

            }
            stack.add(arr[i])
            countStack.add(count)
            res.add(count)
        }else if(arr[i] < stack.last()){
            countStack.add(1)
            res.add(1)
            stack.add(arr[i])
        }
    }
    return res.toTypedArray()
}
