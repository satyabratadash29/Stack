FInd prev and next great element using stack.

fun findNextGreaterElement(arr: IntArray): IntArray {
    val n = arr.size
    val result = IntArray(n)
    val stack = ArrayDeque<Int>()
    for (i in n - 1 downTo 0) {
        while (stack.isNotEmpty() && stack.last() <= arr[i]) {
            stack.removeLast()
        }
        result[i] = if (stack.isEmpty()) -1 else stack.last()
        stack.addLast(arr[i])
    }
    return result
}

fun findPreviousGreatestElement(arr: Array<Int>): Array<Int>{

    val stack = ArrayDeque<Int>()
    val res = mutableListOf<Int>()
    for(i in 0..arr.lastIndex){

        if(stack.isEmpty()){
            res.add(-1)
            stack.addLast(arr[i])
        }else if(stack.last() > arr[i]){
            res.add(stack.last())
            stack.add(arr[i])
        }else if(stack.isNotEmpty() && stack.last() < arr[i]){
            while(stack.isNotEmpty() && stack.last() < arr[i]){
                stack.removeLast()
            }
            if(stack.isEmpty()){
                res.add(-1)
            }else{
                res.add(arr[i])
            }
            stack.addLast(arr[i])
        }
    }

    return res.toTypedArray()
}
